    "fix": "pnpm format:fix && pnpm lint:fix && pnpm typecheck"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "framer-motion": "^12.38.0",
    "random-dungeon-generator": "^1.0.32",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.3.0"
  }
